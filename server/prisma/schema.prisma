// Prisma schema for the AI Code Review Assistant
// Day 2 scope: User, Review, Finding, CodeSubmission models only.
// Review/Finding/CodeSubmission are modeled now (per approved schema) so that
// the foreign keys are correct from the start, but no application logic that
// creates/reads them is implemented until their respective feature days.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AnalysisStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum AIReviewStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  /// AI review was not attempted because no provider API key is configured —
  /// distinct from FAILED, which means a configured provider call failed.
  SKIPPED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews Review[]

  @@map("users")
}

model Review {
  id             String         @id @default(cuid())
  userId         String
  title          String
  language       String
  overallScore   Int?
  aiSummary      String?
  analysisStatus AnalysisStatus @default(PENDING)
  /// Sanitized, user-safe message set only when analysisStatus is FAILED.
  /// Never the raw error/stack trace — see analyzer error handling.
  analysisError  String?

  aiReviewStatus      AIReviewStatus @default(PENDING)
  /// Sanitized, user-safe message set only when aiReviewStatus is FAILED.
  aiReviewError        String?
  aiProvider           String?
  aiModel              String?
  aiProcessingTimeMs   Int?
  aiPromptTokens       Int?
  aiCompletionTokens   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  findings    Finding[]
  submissions CodeSubmission[]

  @@index([userId])
  @@map("reviews")
}

model Finding {
  id           String   @id @default(cuid())
  reviewId     String
  severity     Severity
  /// Human-readable origin of this finding, e.g. "ESLint", "Pylint", or an
  /// AI-review category (e.g. "Security", "Performance") from Day 7.
  category     String
  /// Rule identifier (ESLint ruleId / Pylint symbol) for static findings,
  /// or the AI's finding title for AI-review findings.
  issue        String
  /// The analyzer's descriptive message, or the AI's finding description.
  explanation  String
  /// The analyzer's suggested fix, or the AI's recommendation.
  suggestedFix String?
  lineNumber   Int?
  /// Column position is nullable because not every analyzer/message
  /// includes one (e.g. some Pylint message types are line-only), and AI
  /// findings are not tied to a specific position at all.
  column       Int?
  fileName     String?
  /// Which engine produced this finding: "eslint" | "pylint" | "ai".
  /// Nullable so existing Day 6 rows (predating this column) remain valid.
  source       String?
  createdAt    DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("findings")
}

model CodeSubmission {
  id          String   @id @default(cuid())
  reviewId    String
  sourceCode  String
  fileName    String?
  /// Relative path under the server's upload directory, set only when this
  /// submission came from a file upload (null for pasted code).
  storagePath String?
  language    String
  createdAt   DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("code_submissions")
}
