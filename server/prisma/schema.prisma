// Prisma schema for the AI Code Review Assistant
// Day 2 scope: User, Review, Finding, CodeSubmission models only.
// Review/Finding/CodeSubmission are modeled now (per approved schema) so that
// the foreign keys are correct from the start, but no application logic that
// creates/reads them is implemented until their respective feature days.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AnalysisStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews Review[]

  @@map("users")
}

model Review {
  id             String         @id @default(cuid())
  userId         String
  title          String
  language       String
  overallScore   Int?
  aiSummary      String?
  analysisStatus AnalysisStatus @default(PENDING)
  /// Sanitized, user-safe message set only when analysisStatus is FAILED.
  /// Never the raw error/stack trace — see analyzer error handling.
  analysisError  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  findings    Finding[]
  submissions CodeSubmission[]

  @@index([userId])
  @@map("reviews")
}

model Finding {
  id           String   @id @default(cuid())
  reviewId     String
  severity     Severity
  /// Human-readable origin of this finding, e.g. "ESLint", "Pylint" (Day 6),
  /// or an AI-review category in a future milestone.
  category     String
  /// Rule identifier (ESLint ruleId / Pylint symbol), e.g. "no-unused-vars".
  issue        String
  /// The analyzer's descriptive message for this finding.
  explanation  String
  suggestedFix String?
  lineNumber   Int?
  /// Column position is nullable because not every analyzer/message
  /// includes one (e.g. some Pylint message types are line-only).
  column       Int?
  fileName     String?
  createdAt    DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("findings")
}

model CodeSubmission {
  id          String   @id @default(cuid())
  reviewId    String
  sourceCode  String
  fileName    String?
  /// Relative path under the server's upload directory, set only when this
  /// submission came from a file upload (null for pasted code).
  storagePath String?
  language    String
  createdAt   DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("code_submissions")
}
