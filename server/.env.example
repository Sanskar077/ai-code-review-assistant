NODE_ENV=development
PORT=5000

# Local PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_code_review?schema=public

# Must be at least 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_characters
JWT_EXPIRES_IN=7d

COOKIE_NAME=acr_token
CLIENT_URL=http://localhost:3000

# Where uploaded source files are stored on disk, relative to server/
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# AI review (Day 7). Get a free key at https://openrouter.ai/keys — leave
# blank to run without AI review; the app falls back to static-analysis-only
# results (analysisStatus stays as-is, aiReviewStatus becomes "SKIPPED").
# Free models are suffixed with ":free" — check https://openrouter.ai/models
# for the current list, as free-tier model availability changes over time.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_REVIEW_TIMEOUT_MS=30000
AI_MAX_SOURCE_CHARS=20000
